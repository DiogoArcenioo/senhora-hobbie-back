PORT=3001
# DATABASE_URL nao utilizado pela API (usa DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SYNCHRONIZE=false
DB_SSL=false
# Gere no CMD com:
# powershell -NoProfile -Command "$([guid]::NewGuid().ToString('N') + [guid]::NewGuid().ToString('N'))"
JWT_SECRET=defina_uma_chave_jwt_forte
JWT_EXPIRES_IN=1d
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# SMTP para e-mails de reset de senha
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Clube das Jovens Senhoras <no-reply@seudominio.com>"

# Mercado Pago (Checkout Pro)
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FRONTEND_URL=http://localhost:3000
# URL publica EXATA do endpoint de webhook (prioritaria)
MP_WEBHOOK_URL=
# Alternativa: URL base publica do backend; a API monta /pagamentos/mercado-pago/webhook
BACKEND_PUBLIC_URL=
# Segredo de assinatura de webhook do Mercado Pago (recomendado para validar x-signature)
MP_WEBHOOK_SECRET=

# Supabase
SUPABASE_URL=
# Use a chave "service_role" no backend (nunca expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=user-images
